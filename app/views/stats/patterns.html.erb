<% day_names = %w[Sun Mon Tue Wed Thu Fri Sat] %>

<h1>Listener Patterns</h1>

<nav class="month-nav">
  <%= link_to "‹", stats_patterns_path(month: @prev_month), class: "nav-link" %>
  <span class="month-label"><%= @month_label %></span>
  <% if @month_end <= Date.current %>
    <%= link_to "›", stats_patterns_path(month: @next_month), class: "nav-link" %>
  <% end %>
</nav>

<% @stations.each do |station| %>
  <h2><%= station %></h2>

  <% station_dow = @dow_averages.select { |r| r["station"] == station } %>
  <% if station_dow.any? %>
    <section class="chart-card">
      <header class="chart-header">
        <h3>Day-of-Week Averages</h3>
        <p class="chart-subtitle">Average listeners by day</p>
      </header>
      <%
        dow_chart = station_dow.map do |row|
          [day_names[row["dow"].to_i], row["avg_listeners"].to_i, row["avg_peak"].to_i, row["avg_listeners"].to_i]
        end
      %>
      <%= render BarChartComponent.new(stats: dow_chart) %>
    </section>
  <% end %>

  <%
    station_heatmap = @heatmap.select { |r| r["station"] == station }
    heatmap_data = {}
    heatmap_max = 1
    station_heatmap.each do |row|
      key = [row["dow"].to_i, row["hour"].to_i]
      val = row["avg_listeners"].to_i
      heatmap_data[key] = val
      heatmap_max = val if val > heatmap_max
    end
  %>
  <% if station_heatmap.any? %>
    <section class="chart-card">
      <header class="chart-header">
        <h3>Hour x Day Heatmap</h3>
        <p class="chart-subtitle">Average listeners (darker = more)</p>
      </header>
      <%= render HeatmapComponent.new(data: heatmap_data, day_names: day_names) %>
    </section>
  <% end %>

  <% station_ww = @weekend_weekday.select { |r| r["station"] == station } %>
  <% if station_ww.any? %>
    <section class="chart-card">
      <header class="chart-header">
        <h3>Weekend vs Weekday</h3>
      </header>
      <div class="summary-cards">
        <% station_ww.each do |row| %>
          <div class="summary-card">
            <h3><%= row["period"].capitalize %></h3>
            <p>Avg: <strong><%= row["avg_listeners"] %></strong></p>
            <p>Peak: <strong><%= row["avg_peak"] %></strong></p>
          </div>
        <% end %>
      </div>
    </section>
  <% end %>
<% end %>

<% if @station_comparison.any? %>
  <section class="chart-card">
    <header class="chart-header">
      <h2>Station Comparison</h2>
      <p class="chart-subtitle">Daily averages by station</p>
    </header>
    <table class="data-table">
      <thead>
        <tr>
          <th>Day</th>
          <% comp_stations = @station_comparison.map { |r| r["station"] }.uniq %>
          <% comp_stations.each do |station| %>
            <th><%= station %></th>
          <% end %>
        </tr>
      </thead>
      <tbody>
        <% (0..6).each do |dow| %>
          <tr>
            <td><%= day_names[dow] %></td>
            <% comp_stations.each do |station| %>
              <% row = @station_comparison.find { |r| r["station"] == station && r["dow"].to_i == dow } %>
              <td><%= row ? row["avg_listeners"] : "–" %></td>
            <% end %>
          </tr>
        <% end %>
      </tbody>
    </table>
  </section>
<% end %>
