<nav class="sub-nav">
  <%= link_to "Daily", root_path, class: "nav-link nav-link--active" %>
  <%= link_to "Weekly", stats_weekly_path, class: "nav-link" %>
  <%= link_to "Monthly", stats_monthly_path, class: "nav-link" %>
</nav>

<h1><%= @date_label %> (ICT, UTC+7)</h1>

<% if @surf_radio_stats.any? %>
  <section class="chart-card">
    <header class="chart-header">
      <h2>Surf Radio</h2>
      <p class="chart-subtitle">Listeners per hour</p>
    </header>
    <%= render BarChartComponent.new(stats: @surf_radio_stats) %>
  </section>
<% end %>

<% if @talay_fm_stats.any? %>
  <section class="chart-card">
    <header class="chart-header">
      <h2>Talay FM</h2>
      <p class="chart-subtitle">Listeners per hour</p>
    </header>
    <%= render BarChartComponent.new(stats: @talay_fm_stats) %>
  </section>
<% end %>

<% if @surf_radio_stats.empty? && @talay_fm_stats.empty? %>
  <p>No stats recorded yet.</p>
<% end %>
